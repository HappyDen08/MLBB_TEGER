# Скопіюй у файл .env і заповни
BOT_TOKEN=токен_від_BotFather
CHAT_ID=-100...        # id чату, куди слати опитування (дізнатись командою /chatid)
WEBHOOK_SECRET=будь_який_довгий_рядок   # захист вебхука (необов'язково, але бажано)

# На PythonAnywhere проксі зазвичай вже у середовищі (http_proxy).
# Якщо ні — розкоментуй:
# http_proxy=http://proxy.server:3128
